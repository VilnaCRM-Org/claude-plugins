#!/usr/bin/env bash
# Stub `gh` CLI for bats fixtures (Story 1.3).
# Env config:
#   STUB_GH_VERSION    semver in `gh --version` banner (default: 2.62.0)
#   STUB_GH_EXIT       exit code for every call        (default: 0)
#   STUB_GH_AUTH_EXIT  exit code for `gh auth status`  (default: STUB_GH_EXIT)
#   STUB_GH_OUTPUT     stdout for non-version calls; may hold fixture
#                      GraphQL/REST payloads             (default: none)
#   STUB_GH_LOG        append-log of argv per call       (default: off)
set -euo pipefail
if [[ -n "${STUB_GH_LOG:-}" ]]; then
  printf 'gh %s\n' "$*" >>"$STUB_GH_LOG"
fi
if [[ "${1:-}" == "--version" ]]; then
  printf 'gh version %s (2026-01-01)\n' "${STUB_GH_VERSION:-2.62.0}"
  exit "${STUB_GH_EXIT:-0}"
fi
if [[ "${1:-}" == "auth" && "${2:-}" == "status" ]]; then
  exit "${STUB_GH_AUTH_EXIT:-${STUB_GH_EXIT:-0}}"
fi
if [[ -n "${STUB_GH_OUTPUT:-}" ]]; then
  printf '%s\n' "$STUB_GH_OUTPUT"
fi
exit "${STUB_GH_EXIT:-0}"
